# Copy this file to .env.local and fill in real values. NEVER put real secrets here.
# Neon PostgreSQL — pooled connection string for the app, direct for migrations
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Clerk (invite-only auth). Get from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# Vercel Blob — payment attachment storage
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Comma-separated emails always granted the admin role on sign-in.
ADMIN_EMAILS="you@example.com"
